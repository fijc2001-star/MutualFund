# --- App ---
ENVIRONMENT=development
APP_NAME=MutualFund

# --- Database ---
# Prod: postgresql+asyncpg://user:pass@localhost:5432/mutualfund
# Dev default falls back to local sqlite if unset.
DATABASE_URL=postgresql+asyncpg://mutualfund:mutualfund@localhost:5432/mutualfund

# --- JWT (our own session tokens) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# --- OAuth (Google first; social-first per REQUIREMENTS §5.1) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# --- Root admin bootstrap (REQUIREMENTS §1.1) ---
ROOT_ADMIN_EMAIL=root@example.com
DEFAULT_TENANT_ID=00000000000000000000000000000000

# --- Market data (REQUIREMENTS §6) ---
# fake | schwab
MARKETDATA_PROVIDER=fake
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REFRESH_TOKEN=
SCHWAB_API_BASE=https://api.schwabapi.com
SCHWAB_TOKEN_URL=https://api.schwabapi.com/v1/oauth/token
